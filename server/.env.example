# ---- Server ----
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed browser origins (the Vite dev server, prod URL, etc.)
CLIENT_ORIGIN=http://localhost:5173

# ---- Database ----
# Local dev should use a local/throwaway DB. NEVER point local dev or test at a
# production cluster. Provide the production connection string via your host's
# environment / a secret manager — not via a committed file.
MONGODB_URI=mongodb://127.0.0.1:27017/tournament_manager

# ---- Auth ----
# REQUIRED in any non-dev environment: long random strings, >= 32 chars.
# Generate with: openssl rand -hex 48
#   (or) node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating these values immediately invalidates all issued access/refresh tokens.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional shared rate-limit store (recommended in multi-instance deployments).
# Leave empty to use in-memory per-process limiting.
RATE_LIMIT_REDIS_URL=

# ---- Seed super admin (used by `npm run seed`) ----
# This is the fixed Super Admin sign-in password. It is not changeable via API/UI.
# Rotate by updating this value and running `npm run seed`.
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@tms.local
SEED_ADMIN_PASSWORD=admin12345
# Set true to force-sync the super-admin password on each server boot.
# In production, prefer false so restarts do not reset credentials unexpectedly.
SYNC_SEED_ADMIN_PASSWORD=true

# ---- Demo organiser (used by `npm run seed:demo`) ----
# Creates a tournament-admin account that owns the sample tournaments. Re-running
# the demo seed only ever wipes/recreates data owned by this account.
SEED_DEMO_NAME=Demo Organiser
SEED_DEMO_EMAIL=demo@tms.local
SEED_DEMO_PASSWORD=demo12345

# ---- Image storage (Cloudinary) ----
# When set, image uploads (team/tournament logos & banners) are stored on
# Cloudinary and served from its CDN. Leave blank to use local-disk storage
# under server/uploads (served at /uploads). Get keys from the Cloudinary
# dashboard (Settings -> API Keys). Alternatively set a single CLOUDINARY_URL.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tourneyops
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ---- Email (password reset, notifications) ----
# Leave SMTP_HOST blank in local dev — emails are logged to the server console
# instead of being sent, so flows like password reset still work end-to-end.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=TourneyOps <no-reply@tourneyops.local>
# Base URL of the web app, used to build links in emails. Defaults to the first
# CLIENT_ORIGIN when unset.
APP_URL=http://localhost:5173
